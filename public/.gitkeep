/* ============================================================
   SHARING SUN, INC. — design system
   Palette: ink navy on warm white, solar amber accent
   Type: Archivo (display + body), IBM Plex Mono (labels/credentials)
   ============================================================ */

:root {
  --ink: #15243b;        /* headlines, body text */
  --ink-soft: #44546c;   /* secondary text */
  --paper: #ffffff;      /* page background */
  --cloud: #f2f5f9;      /* alternate section background */
  --line: #dde4ec;       /* hairline borders */
  --amber: #f6a81c;      /* primary accent (evolved from #ffb90f) */
  --amber-deep: #d98a06; /* hover / pressed accent */
  --dusk: #0e1a2e;       /* footer, dark band */
  --radius: 10px;
  --container: 1120px;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-archivo), system-ui, sans-serif;
  font-size: 17px;
  line-height: 1.6;
  color: var(--ink);
  background: var(--paper);
}

a {
  color: inherit;
  text-decoration: none;
}

a:focus-visible,
button:focus-visible {
  outline: 3px solid var(--amber);
  outline-offset: 2px;
  border-radius: 4px;
}

.container {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 24px;
}

/* ---------- header ---------- */

.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--line);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding-top: 14px;
  padding-bottom: 14px;
  flex-wrap: wrap;
}

.wordmark {
  font-weight: 800;
  font-size: 1.15rem;
  letter-spacing: 0.06em;
  display: flex;
  align-items: center;
  gap: 10px;
  white-space: nowrap;
}

.wordmark-sun {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #ffd266, var(--amber) 70%);
  box-shadow: 0 0 0 3px rgba(246, 168, 28, 0.25);
}

.wordmark-logo {
  width: 30px;
  height: 30px;
  object-fit: contain;
  display: block;
}

.main-nav {
  display: flex;
  align-items: center;
  gap: 22px;
  flex-wrap: wrap;
  font-size: 0.95rem;
  font-weight: 500;
}

.main-nav a:not(.nav-cta):hover {
  color: var(--amber-deep);
}

.nav-cta,
.btn-amber {
  background: var(--amber);
  color: var(--ink);
  font-weight: 700;
  padding: 10px 20px;
  border-radius: var(--radius);
  transition: background 0.15s ease;
  border: none;
  font-size: 1rem;
  cursor: pointer;
  font-family: inherit;
  display: inline-block;
}

.nav-cta:hover,
.btn-amber:hover {
  background: var(--amber-deep);
  color: #fff;
}

.btn-ghost {
  font-weight: 700;
  padding: 10px 20px;
  border-radius: var(--radius);
  border: 2px solid var(--ink);
  transition: background 0.15s ease, color 0.15s ease;
  display: inline-block;
}

.btn-ghost:hover {
  background: var(--ink);
  color: #fff;
}

/* ---------- shared section bits ---------- */

.eyebrow {
  font-family: var(--font-mono), monospace;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  color: var(--amber-deep);
  text-transform: uppercase;
  margin-bottom: 14px;
}

.section {
  padding: 88px 0;
}

.section-cloud {
  background: var(--cloud);
}

.section h2 {
  font-size: clamp(1.7rem, 3.5vw, 2.4rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.01em;
  margin-bottom: 16px;
}

.section .lede {
  color: var(--ink-soft);
  max-width: 640px;
  margin-bottom: 40px;
}

.mono-line {
  font-family: var(--font-mono), monospace;
  font-size: 0.8rem;
  letter-spacing: 0.08em;
}

/* ---------- interior page hero ---------- */

.page-hero {
  padding: 72px 0 56px;
  border-bottom: 1px solid var(--line);
}

.page-hero h1 {
  font-size: clamp(2rem, 4.5vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 18px;
  max-width: 760px;
}

.page-hero .lede {
  color: var(--ink-soft);
  font-size: 1.08rem;
  max-width: 640px;
}

/* ---------- homepage hero ---------- */

.hero {
  padding: 96px 0 72px;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 56px;
  align-items: center;
}

.hero h1 {
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.02em;
  margin-bottom: 22px;
}

.hero h1 .accent {
  color: var(--amber-deep);
}

.hero p {
  color: var(--ink-soft);
  font-size: 1.08rem;
  max-width: 540px;
  margin-bottom: 32px;
}

.hero-ctas {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

/* hero array graphic */

.array-figure {
  width: 100%;
}

.array-figure svg {
  width: 100%;
  height: auto;
  display: block;
}

.cell {
  fill: #243753;
  stroke: #0e1a2e;
  stroke-width: 1.5;
  animation: energize 0.5s ease forwards;
  animation-delay: var(--d, 0s);
}

@keyframes energize {
  to {
    fill: var(--amber);
  }
}

.sun-arc {
  fill: none;
  stroke: var(--amber);
  stroke-width: 3;
  stroke-dasharray: 4 8;
  opacity: 0.7;
}

@media (prefers-reduced-motion: reduce) {
  .cell {
    animation: none;
    fill: var(--amber);
  }
  html {
    scroll-behavior: auto;
  }
}

/* ---------- trust strip ---------- */

.trust-strip {
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  background: var(--paper);
  padding: 18px 0;
}

.trust-strip .container {
  display: flex;
  gap: 14px 40px;
  flex-wrap: wrap;
  justify-content: center;
}

.trust-strip span {
  font-family: var(--font-mono), monospace;
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  color: var(--ink-soft);
}

/* ---------- service cards ---------- */

.card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22px;
}

.card {
  display: block;
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 30px 28px;
  transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
}

.card:hover {
  border-color: var(--amber);
  transform: translateY(-3px);
  box-shadow: 0 10px 28px rgba(21, 36, 59, 0.08);
}

.card h3 {
  font-size: 1.25rem;
  font-weight: 800;
  margin-bottom: 10px;
}

.card p {
  color: var(--ink-soft);
  font-size: 0.98rem;
  margin-bottom: 16px;
}

.card .card-link {
  font-weight: 700;
  color: var(--amber-deep);
  font-size: 0.95rem;
}

/* static (non-link) version of the card */

.card-static {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 30px 28px;
}

.card-static h3 {
  font-size: 1.25rem;
  font-weight: 800;
  margin-bottom: 10px;
}

.card-static p {
  color: var(--ink-soft);
  font-size: 0.98rem;
}

/* ---------- numbered process steps ---------- */

.steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 22px;
  counter-reset: step;
}

.step {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 26px 24px;
}

.step::before {
  counter-increment: step;
  content: "0" counter(step);
  font-family: var(--font-mono), monospace;
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  color: var(--amber-deep);
  display: block;
  margin-bottom: 12px;
}

.step h3 {
  font-size: 1.05rem;
  font-weight: 800;
  margin-bottom: 8px;
}

.step p {
  color: var(--ink-soft);
  font-size: 0.92rem;
}

/* ---------- roofer band ---------- */

.band {
  background: var(--dusk);
  color: #fff;
  padding: 72px 0;
}

.band-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
}

.band h2 {
  font-size: clamp(1.5rem, 3vw, 2.1rem);
  font-weight: 800;
  line-height: 1.2;
  max-width: 560px;
}

.band p {
  color: #b9c4d6;
  max-width: 560px;
  margin-top: 12px;
}

/* ---------- financing teaser ---------- */

.fin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
}

.fin-card {
  border-left: 4px solid var(--amber);
  background: var(--paper);
  border-radius: 0 var(--radius) var(--radius) 0;
  padding: 26px 28px;
  border-top: 1px solid var(--line);
  border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.fin-card h3 {
  font-size: 1.1rem;
  font-weight: 800;
  margin-bottom: 8px;
}

.fin-card p {
  color: var(--ink-soft);
  font-size: 0.97rem;
}

/* ---------- contact page ---------- */

.contact-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 48px;
  align-items: start;
}

.quote-form {
  display: grid;
  gap: 18px;
}

.field label {
  display: block;
  font-weight: 700;
  font-size: 0.92rem;
  margin-bottom: 6px;
}

.field input,
.field select,
.field textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  font-family: inherit;
  font-size: 1rem;
  color: var(--ink);
  background: var(--paper);
}

.field input:focus,
.field select:focus,
.field textarea:focus {
  outline: 3px solid var(--amber);
  outline-offset: 1px;
  border-color: var(--amber);
}

.field textarea {
  min-height: 140px;
  resize: vertical;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}

.contact-aside {
  background: var(--cloud);
  border-radius: var(--radius);
  padding: 30px 28px;
}

.contact-aside h2 {
  font-size: 1.3rem;
  font-weight: 800;
  margin-bottom: 18px;
}

.contact-aside p {
  margin-bottom: 14px;
  color: var(--ink-soft);
}

.contact-aside a {
  color: var(--amber-deep);
  font-weight: 700;
}

/* ---------- footer ---------- */

.site-footer {
  background: var(--dusk);
  color: #cdd6e4;
  padding: 56px 0 28px;
  font-size: 0.95rem;
}

.footer-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  padding-bottom: 36px;
}

.footer-name {
  font-weight: 800;
  color: #fff;
  font-size: 1.05rem;
  margin-bottom: 6px;
}

.footer-label {
  font-family: var(--font-mono), monospace;
  font-size: 0.75rem;
  letter-spacing: 0.14em;
  color: var(--amber);
  text-transform: uppercase;
  margin-bottom: 8px;
}

.site-footer a:hover {
  color: var(--amber);
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.12);
  padding-top: 22px;
  font-size: 0.85rem;
  color: #8b99ad;
}

/* ---------- responsive ---------- */

@media (max-width: 860px) {
  .hero {
    padding: 64px 0 48px;
  }
  .hero-grid,
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .card-grid,
  .fin-grid,
  .footer-grid,
  .field-row {
    grid-template-columns: 1fr;
  }
  .steps {
    grid-template-columns: 1fr 1fr;
  }
  .section {
    padding: 64px 0;
  }
}

@media (max-width: 520px) {
  .steps {
    grid-template-columns: 1fr;
  }
}

/* ---------- credential chips ---------- */

.cred-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 8px;
}

.cred-chip {
  font-family: var(--font-mono), monospace;
  font-size: 0.78rem;
  letter-spacing: 0.1em;
  color: var(--ink);
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 10px 18px;
  white-space: nowrap;
  position: relative;
  padding-left: 30px;
}

.cred-chip::before {
  content: "";
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--amber);
}

/* ---------- logo strip ---------- */

.logo-strip {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16px;
  margin-top: 8px;
}

.logo-tile {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  aspect-ratio: 44 / 26;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
}

.logo-tile:hover {
  border-color: var(--amber);
  box-shadow: 0 6px 18px rgba(21, 36, 59, 0.07);
}

.logo-tile img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  display: block;
}

@media (max-width: 860px) {
  .logo-strip {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 520px) {
  .logo-strip {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ---------- scroll reveal ---------- */

[data-animate] {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
  will-change: opacity, transform;
}

[data-animate].is-visible {
  opacity: 1;
  transform: none;
}

@media (prefers-reduced-motion: reduce) {
  [data-animate] {
    opacity: 1;
    transform: none;
    transition: none;
  }
}

/* ---------- panel-grid background texture ---------- */

.section-cloud {
  position: relative;
  overflow: hidden;
}

.section-cloud::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(21, 36, 59, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(21, 36, 59, 0.035) 1px, transparent 1px);
  background-size: 46px 30px;
  pointer-events: none;
  z-index: 0;
}

.section-cloud > .container {
  position: relative;
  z-index: 1;
}
